# Production template. Copy values into your hosting provider secret manager.
# Never commit real credentials.

APP_ENV=production
API_HOST=127.0.0.1
API_PORT=8000
API_DEBUG=false

DEMO_MODE=false
SCRAPER_ALLOW_FALLBACKS=false

AUTH_ENABLED=true
AUTH_USERNAME=admin
AUTH_PASSWORD=replace-with-a-long-random-password
AUTH_SECRET_KEY=replace-with-a-long-random-secret
AUTH_TOKEN_TTL_MINUTES=720
AUTH_COOKIE_SECURE=true
AUTH_RETURN_BEARER_TOKEN=false
AUTH_LOGIN_MAX_FAILURES=5
AUTH_LOGIN_LOCKOUT_SECONDS=300

STORAGE_BACKEND=supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=replace-with-anon-key
SUPABASE_SERVICE_KEY=replace-with-service-role-key
SUPABASE_STORAGE_BUCKET=jobhunter-documents

CORS_ALLOWED_ORIGINS=https://your-domain.example

SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
EMAIL_USER=
EMAIL_PASSWORD=

# AI email generation (optional)
GROQ_API_KEY=
# Backward-compatible typo alias supported by the backend: GROG_API_KEY
GROQ_MODEL=llama-3.3-70b-versatile

NOTIFICATION_WEBHOOK=
TELEGRAM_CHAT_ID=
